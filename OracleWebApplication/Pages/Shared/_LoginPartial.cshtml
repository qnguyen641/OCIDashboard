@using Microsoft.AspNetCore.Identity
@using OracleWebApplication.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <span class="nav-link text-dark">@L.Get("Nav_Hello", UserManager.GetUserName(User)!)</span>
        </li>
        <li class="nav-item">
            <form asp-page="/Account/Logout" method="post" class="d-inline">
                <button type="submit" class="nav-link btn btn-link text-dark">@L["Nav_Logout"]</button>
            </form>
        </li>
    </ul>
}
else
{
    <ul class="navbar-nav">
        <li class="nav-item">
            <a class="nav-link text-dark" asp-page="/Account/Register">@L["Nav_Register"]</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-page="/Account/Login">@L["Nav_Login"]</a>
        </li>
    </ul>
}
