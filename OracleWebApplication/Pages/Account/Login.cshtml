@page
@model OracleWebApplication.Pages.Account.LoginModel
@{
    ViewData["Title"] = L["Login_Title"];
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1>@ViewData["Title"]</h1>
        <hr />
        <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">@L["Login_Email"]</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="username" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Password" class="form-label">@L["Login_Password"]</label>
                <input asp-for="Input.Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label">@L["Login_RememberMe"]</label>
            </div>
            <button type="submit" class="btn btn-primary w-100">@L["Login_Submit"]</button>
        </form>
        <div class="mt-3 text-center">
            <p><a asp-page="/Account/ForgotPassword">@L["Login_ForgotPassword"]</a></p>
            <p><a asp-page="/Account/Register" asp-route-returnUrl="@Model.ReturnUrl">@L["Login_CreateAccount"]</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
