@page
@model OracleWebApplication.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = L["ForgotPw_Title"];
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1>@ViewData["Title"]</h1>
        <p class="text-muted">@L["ForgotPw_Desc"]</p>
        <hr />
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label">@L["Login_Email"]</label>
                <input asp-for="Input.Email" class="form-control" autocomplete="email" placeholder="your@email.com" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100">@L["ForgotPw_Submit"]</button>
        </form>
        <div class="mt-3 text-center">
            <a asp-page="/Account/Login">@L["ForgotPw_BackToLogin"]</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
